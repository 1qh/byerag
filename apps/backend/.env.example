# apps/backend/.env — single source of truth for ALL env vars (backend + web + cli).
# Copy this file to .env and fill every value. `bun sync --once` fails loudly if any are missing.
# Convex self-hosted deployment
# Both URLs name the same Convex deployment and MUST be identical.
# Get these from your Convex self-hosted dashboard after provisioning.
CONVEX_SELF_HOSTED_URL=https://your-convex-api.example.com
CONVEX_SELF_HOSTED_ADMIN_KEY=convex-self-hosted|<admin-key-from-dashboard>
NEXT_PUBLIC_CONVEX_URL=https://your-convex-api.example.com
# Convex HTTP action URL (different hostname than above — serves httpActions)
CONVEX_SITE_URL=https://your-convex-backend.example.com
# Anthropic — subscription OAuth token, auto-refreshed from macOS keychain by `bun sync`.
# Leave as `auto` on macOS; set to actual token on Linux/Windows.
ANTHROPIC_API_KEY=auto
# E2B sandbox API
# Get from https://e2b.dev — create an account, then generate a key
E2B_API_KEY=e2b_<your-key>
# E2B template id — must be a pre-built template containing Claude Code CLI + bun + workspace layout.
# Build once via `e2b template build`, then reference the id here.
TEMPLATE_ID=claude-sandbox
# Google OAuth (Convex Auth provider)
# Create an OAuth 2.0 client at https://console.cloud.google.com
AUTH_GOOGLE_ID=<client-id>.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=GOCSPX-<client-secret>
# Authz allowlist — comma-separated emails allowed to sign in
ALLOWED_EMAILS=you@example.com,teammate@example.com
# Web app URL (OAuth redirect target)
SITE_URL=https://your-deployment.vercel.app
# Shared secret for test/integration auth
# Generate once: `openssl rand -hex 16`
TEST_SECRET=<32-hex-chars>
