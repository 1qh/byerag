{
  "name": "admin",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./server/index.ts",
    "./server/*": "./server/*.ts"
  },
  "scripts": {
    "build": "bun --env-file=../backend/.env next build",
    "dev": "bun --env-file=../backend/.env next dev --turbo --port 3000",
    "print-prompt": "bun scripts/print-prompt.ts",
    "probe:live": "bun scripts/probe-live.ts",
    "smoke": "bun scripts/smoke.ts",
    "start": "bun --env-file=../backend/.env next start --port 3000",
    "test": "bun test src server"
  },
  "dependencies": {
    "@a/react": "workspace:*",
    "@a/ui": "workspace:*",
    "@convex-dev/auth": "latest",
    "backend": "workspace:*",
    "convex": "latest",
    "idecn": "latest",
    "next": "latest",
    "next-themes": "latest",
    "react": "latest",
    "react-dom": "latest",
    "streamdown": "latest"
  }
}
