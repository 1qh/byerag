{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "ALLOWED_EMAILS",
    "ANTHROPIC_API_KEY",
    "CLI_SESSION_ID",
    "CLI_SESSION_SECRET",
    "CONVEX_SELF_HOSTED_ADMIN_KEY",
    "CONVEX_SELF_HOSTED_URL",
    "CONVEX_SITE_URL",
    "E2B_API_KEY",
    "NEXT_PUBLIC_CONVEX_URL",
    "NODE_TLS_REJECT_UNAUTHORIZED",
    "TEST_SECRET",
    "TOOLS_ROOT",
    "X_API_KEY"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"]
    },
    "check": {
      "dependsOn": ["build"],
      "cache": false
    },
    "fix": {
      "dependsOn": ["build"],
      "cache": false
    }
  }
}
