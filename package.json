{
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*",
    "readonly/ui"
  ],
  "scripts": {
    "action": "sh up.sh",
    "build": "bash -c \"turbo build --output-logs=errors-only 2> >(grep -vE 'WARNING|Could not resolve workspaces|missing field|Turborepo will still function' >&2)\"",
    "check": "lintmax check",
    "clean": "sh clean.sh",
    "deploy": "bun --filter=backend run deploy",
    "dev": "turbo dev",
    "fix": "lintmax fix",
    "postinstall": "sherif",
    "new-app": "bun scripts/new-app.ts",
    "prepare": "bunx simple-git-hooks",
    "prod": "sh prod.sh",
    "sync": "bun --filter=backend run sync",
    "test": "bun --env-file=apps/backend/.env test apps/backend packages/cli && bun --filter='./packages/react' run test && bun --filter='./apps/*' run test",
    "test:e2e": "bun --env-file=apps/backend/.env test --parallel=1 apps/*/tests-e2e/"
  },
  "simple-git-hooks": {
    "pre-commit": "sh up.sh && git add -u"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "latest"
  },
  "devDependencies": {
    "@anthropic-ai/claude-code": "latest",
    "@happy-dom/global-registrator": "latest",
    "@testing-library/dom": "latest",
    "@testing-library/react": "latest",
    "convex-test": "latest",
    "drizzle-kit": "latest",
    "fast-check": "latest",
    "lintmax": "latest",
    "sherif": "latest",
    "simple-git-hooks": "latest",
    "tsdown": "latest",
    "turbo": "latest",
    "typescript": "latest",
    "unrun": "latest"
  },
  "packageManager": "bun@1.3.14",
  "trustedDependencies": [
    "esbuild",
    "lintmax",
    "msw",
    "sharp",
    "simple-git-hooks"
  ]
}
